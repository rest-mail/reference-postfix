# Postfix main.cf — generic reference image
# Rendered from template by /usr/local/bin/entrypoint.sh.
# Override anything by mounting files into /etc/postfix-overlay/.

# Identity
smtpd_banner = ${POSTFIX_HOSTNAME} ESMTP
myhostname = ${POSTFIX_HOSTNAME}
mydomain = ${POSTFIX_DOMAIN}
myorigin = ${POSTFIX_DOMAIN}
mydestination =
mynetworks = ${POSTFIX_MYNETWORKS}

# Misc
biff = no
append_dot_mydomain = no
readme_directory = no
compatibility_level = 3.6

# Virtual domain configuration (database-driven via pgsql lookup tables).
# The lookup .cf files live in the overlay (or are mounted at /etc/postfix/sql/).
virtual_mailbox_domains = pgsql:/etc/postfix/sql/virtual_domains.cf
virtual_mailbox_maps    = pgsql:/etc/postfix/sql/virtual_mailboxes.cf
virtual_alias_maps      = pgsql:/etc/postfix/sql/virtual_aliases.cf

# Virtual mailbox UID/GID (5000:5000 by default; override via overlay if needed).
virtual_mailbox_base = /var/mail/vhosts
virtual_minimum_uid  = 5000
virtual_uid_maps     = static:5000
virtual_gid_maps     = static:5000

# Delivery transport for virtual mailboxes. Defaults to Postfix's own `virtual`
# agent (writes maildirs under virtual_mailbox_base). Set POSTFIX_VIRTUAL_TRANSPORT
# to hand delivery to a Dovecot LMTP listener instead — e.g. lmtp:inet:mail-dovecot:24
# — so Dovecot owns the maildir (single writer; enables sieve and quota enforcement).
virtual_transport = ${POSTFIX_VIRTUAL_TRANSPORT}

# TLS
smtpd_tls_cert_file       = ${POSTFIX_TLS_CERT}
smtpd_tls_key_file        = ${POSTFIX_TLS_KEY}
smtpd_tls_security_level  = may
smtpd_tls_auth_only       = yes
smtpd_tls_loglevel        = 1
smtpd_tls_received_header = yes

smtp_tls_security_level = may
smtp_tls_loglevel       = 1

# SASL — off on port 25 (smtp). The submission/smtps services in master.cf
# enable it per-service; the backend (smtpd_sasl_type/path) and any milters are
# wired by entrypoint.sh ONLY when POSTFIX_SASL_PATH / POSTFIX_MILTERS are set.
# (An empty smtpd_sasl_path is a fatal postfix error, so it must not be emitted
# unconditionally — this keeps the image standalone-runnable with SASL unset.)
smtpd_sasl_auth_enable      = no
smtpd_sasl_security_options = noanonymous

# Restrictions
smtpd_recipient_restrictions =
    permit_sasl_authenticated,
    permit_mynetworks,
    reject_unauth_destination

smtpd_relay_restrictions =
    permit_sasl_authenticated,
    permit_mynetworks,
    reject_unauth_destination

# Limits
message_size_limit       = 10240000
maximal_queue_lifetime   = 5d
bounce_queue_lifetime    = 5d

# Logging — postfix logs via syslog; the rsyslog co-process forwards mail.* to stdout.
maillog_file =
